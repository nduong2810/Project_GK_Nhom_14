<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="language-center-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entity classes -->
        <class>vn.edu.ute.model.Student</class>
        <class>vn.edu.ute.model.Teacher</class>
        <class>vn.edu.ute.model.Course</class>
        <class>vn.edu.ute.model.Room</class>
        <class>vn.edu.ute.model.Branch</class>
        <class>vn.edu.ute.model.ClassEntity</class>
        <class>vn.edu.ute.model.Enrollment</class>
        <class>vn.edu.ute.model.Invoice</class>
        <class>vn.edu.ute.model.Payment</class>
        <class>vn.edu.ute.model.Schedule</class>
        <class>vn.edu.ute.model.Attendance</class>
        <class>vn.edu.ute.model.Staff</class>
        <class>vn.edu.ute.model.UserAccount</class>
        <class>vn.edu.ute.model.Result</class>
        <class>vn.edu.ute.model.Promotion</class>
        <class>vn.edu.ute.model.PlacementTest</class>
        <class>vn.edu.ute.model.Certificate</class>
        <class>vn.edu.ute.model.Notification</class>

        <properties>
            <!-- Database connection settings -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/mis_language_center?useSSL=false&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.password" value="Ngoctai2005@@"/>

            <!-- Hibernate settings -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Connection pool settings -->
            <property name="hibernate.connection.pool_size" value="10"/>
        </properties>
    </persistence-unit>

</persistence>
